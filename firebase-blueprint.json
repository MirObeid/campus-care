{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "staff", "faculty", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Complaint": {
      "title": "Complaint",
      "description": "A complaint logged by a student or staff member",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reporterUid": { "type": "string" },
        "reporterName": { "type": "string" },
        "category": { "type": "string", "enum": ["Maintenance", "Academic", "Security", "Administrative", "Other"] },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Assigned", "In Progress", "Resolved", "Rejected"] },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
        "assignedTo": { "type": "string" },
        "adminNotes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["reporterUid", "category", "description", "location", "status", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user about their complaint",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "complaintId": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "complaintId", "message", "read", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/complaints/{complaintId}": {
      "schema": "Complaint",
      "description": "Complaints collection"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
